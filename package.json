{
  "name": "condition-editor-coding-exercise",
  "version": "0.0.0",
  "private": true,
  "description": "Product Filtering Condition Editor UI",
  "repository": "",
  "license": "MIT",
  "author": "",
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./app/*"
  },
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "build": "vite build",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"yarn:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:css:fix": "concurrently \"yarn:lint:css -- --fix\"",
    "lint:fix": "concurrently \"yarn:lint:*:fix\" --names \"fix:\" --prefixColors auto && yarn format",
    "lint:format": "prettier . --cache --check",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "start": "vite",
    "test": "vite build --mode development && ember test --path dist"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/runtime": "^7.29.2",
    "@ember/optional-features": "^3.0.0",
    "@ember/string": "^4.0.1",
    "@ember/test-helpers": "^5.4.1",
    "@ember/test-waiters": "^4.1.1",
    "@embroider/compat": "^4.1.17",
    "@embroider/config-meta-loader": "^1.0.0",
    "@embroider/core": "^4.4.7",
    "@embroider/legacy-inspector-support": "^0.1.3",
    "@embroider/macros": "^1.20.2",
    "@embroider/router": "^3.0.6",
    "@embroider/vite": "^1.7.2",
    "@eslint/js": "^9.39.4",
    "@glimmer/component": "^2.0.0",
    "@rollup/plugin-babel": "^7.0.0",
    "@warp-drive/core": "~5.8.1",
    "@warp-drive/ember": "~5.8.1",
    "@warp-drive/json-api": "~5.8.1",
    "@warp-drive/legacy": "~5.8.1",
    "@warp-drive/utilities": "~5.8.1",
    "babel-plugin-ember-template-compilation": "^3.1.0",
    "concurrently": "^9.2.1",
    "decorator-transforms": "^2.3.1",
    "ember-cli": "~6.12.0",
    "ember-cli-babel": "^8.3.1",
    "ember-cli-deprecation-workflow": "^3.4.0",
    "ember-load-initializers": "^3.0.1",
    "ember-modifier": "^4.3.0",
    "ember-page-title": "^9.0.3",
    "ember-qunit": "^9.0.4",
    "ember-resolver": "^13.2.0",
    "ember-source": "~6.12.0",
    "ember-template-lint": "^7.9.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ember": "^12.7.5",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-qunit": "^8.2.6",
    "eslint-plugin-warp-drive": "^5.8.1",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "prettier-plugin-ember-template-tag": "^2.1.3",
    "qunit": "^2.25.0",
    "qunit-dom": "^3.5.0",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^38.0.0",
    "testem": "^3.19.1",
    "vite": "^8.0.10"
  },
  "engines": {
    "node": ">= 20.19.0"
  },
  "ember": {
    "edition": "octane"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
